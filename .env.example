# At least one provider key is required for real built-in AI organization.
# Provider order is tried from left to right.
AI_PROVIDER_ORDER=deepseek,openai,zhipu

# DeepSeek OpenAI-compatible provider.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI or OpenAI-compatible provider.
OPENAI_API_KEY=sk-your-key

# Use any vision-capable OpenAI or OpenAI-compatible model.
OPENAI_MODEL=gpt-4o-mini

# Optional: point to an OpenAI-compatible endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Zhipu AI / BigModel OpenAI-compatible endpoint.
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Change in production.
AUTH_SECRET=replace-with-a-long-random-secret
